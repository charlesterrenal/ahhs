# ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env and fill in your actual values

# SYSTEM CONFIGURATION
TIMEZONE=America/New_York
PUID=1000
PGID=1000

# NETWORK CONFIGURATION
# Your server's LAN IP address (e.g., 192.168.1.100)
SERVER_IP=192.168.1.100
# Your domain name (if using reverse proxy)
BASE_DOMAIN=example.com

# LOCALSTACK CONFIGURATION
# LocalStack Pro auth token (get from https://app.localstack.cloud)
LOCALSTACK_AUTH_TOKEN=ls-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# LocalStack domain/subdomain
LOCALSTACK_DOMAIN=aws.example.com
# Debug mode (0 or 1)
DEBUG=0
# Enable persistence (0 or 1)
PERSISTENCE=1

# N8N CONFIGURATION
# N8N domain
N8N_DOMAIN=n8n.example.com
# N8N encryption key (generate with: openssl rand -base64 32)
N8N_ENCRYPTION_KEY=GENERATE_A_RANDOM_32_CHARACTER_KEY_HERE


# VAULTWARDEN CONFIGURATION
# Vaultwarden domain
VAULTWARDEN_DOMAIN=vault.example.com
# Admin token (generate with: openssl rand -base64 32)
VAULTWARDEN_ADMIN_TOKEN=GENERATE_A_RANDOM_ADMIN_TOKEN_HERE
# Allow new signups (true/false)
SIGNUPS_ALLOWED=false
# Allow invitations (true/false)
INVITATIONS_ALLOWED=true
# JELLYFIN MEDIA PATHS
MEDIA_PATH_ANIME=/path/to/your/anime
MEDIA_PATH_MOVIES=/path/to/your/movies
MEDIA_PATH_SERIES=/path/to/your/series


# CLOUDFLARE TUNNEL
# Your Cloudflare Tunnel token
CF_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# OPTIONAL: PIHOLE CONFIGURATION
# PiHole web interface password
# PIHOLE_PASSWORD=your_secure_password_here


# SECURITY NOTES
# 1. Always use strong, randomly generated passwords
# 2. Never use the same password twice
# 3. Store this .env file securely
# 4. Never commit .env to version control
# 5. Use a password manager (like your own Vaultwarden!)
# 6. Generate random keys with: openssl rand -base64 32
